<UXML xmlns="UnityEngine.UIElements">
    <VisualElement name="AISkillsBlock" class="project-settings-title-container">
        <Label text="AI Skills" class="project-settings-title"/>
        <Label text="Claude Code skills for Unity IAP development assistance" class="label-container"/>
        <VisualElement class="button-container">
            <Button name="OpenSkillsFolderButton" text="Open Skills Folder" class="submit-button"/>
            <Button name="InstallSkillsButton" text="Install to Claude Code" class="submit-button"/>
        </VisualElement>
    </VisualElement>
    <VisualElement class="separator" />
</UXML>
